+<script>
+'use strict';
+/* ─────────────────────────────────────────────────────────────────────
+   Caspian Shift — Budget Tool
+   Vanilla JS port of the React design. No framework. No build step.
+   Pages: landing → wizard → loading → results.
+   API endpoints: /api/step1, /api/step2, /api/step3, /api/results, /api/capture-email
+   On localhost / file://, calls fall through gracefully; results always render.
+   ───────────────────────────────────────────────────────────────────── */
+
+// ────────────────── CONSTANTS (mirrors budget-data.jsx + spec) ──────────────────
+const COUNTRIES = [
+  'United States','Canada','United Kingdom','France','Germany','Spain','Italy',
+  'Netherlands','Sweden','Finland','Poland','Czechia','Slovenia','Brazil','Japan'
+];
+const COUNTRY_SALARIES = {
+  'United States':9500,'Canada':7200,'United Kingdom':6800,'France':5500,'Germany':6200,
+  'Spain':4200,'Italy':4000,'Netherlands':6500,'Sweden':6300,'Finland':6000,
+  'Poland':3800,'Czechia':3500,'Slovenia':3000,'Brazil':2800,'Japan':5000,'Other':4500
+};
+const STATUSES = ['Concept','Prototype','Vertical Slice','Demo','In Development','Alpha','Beta'];
+const GENRES = [
+  'Action','Adventure','RPG','Strategy','Simulation','Puzzle','Platformer','Horror',
+  'Survival','Roguelike','Visual Novel','Metroidvania','City Builder','Tower Defense',
+  'Racing','Fighting','Shooter','Stealth','Sandbox','Card Game','Narrative','Rhythm'
+];
+const FUNDING_TYPES = ['Self-Funded','Crowdfunding','Publisher','Grant'];
+
+const PROV_ICONS = {
+  provided:  { symbol: '✓', color: '#17BEBB', label: 'You provided' },
+  estimated: { symbol: '·', color: '#FAF0CA', label: 'We estimated' },
+  adjusted:  { symbol: '⟳', color: '#FC7A1E', label: 'We adjusted' },
+};
+const BUDGET_LABELS = {
+  dev: 'Development & QA', art: 'Art & Illustrations', music: 'Music & Sound',
+  loc: 'Localization', marketing: 'Marketing', overhead: 'Overhead', preRelease: 'Pre-Release',
+};
+
+// ────────────────── DOM HELPERS (mini React-like h() factory) ──────────────────
+/**
+ * h(tag, attrs?, ...children) — create an HTMLElement.
+ * `attrs` keys: style (string|object), className/class, dataset object,
+ * onclick / onchange / on* (event handlers), html (innerHTML), or any DOM attr.
+ * children: strings → text nodes; arrays → flattened; null/undefined skipped.
+ */
+function h(tag, attrs, ...children) {
+  const el = document.createElement(tag);
+  if (attrs && typeof attrs === 'object' && !(attrs instanceof Node) && !Array.isArray(attrs)) {
+    for (const k in attrs) {
+      const v = attrs[k];
+      if (v == null || v === false) continue;
+      if (k === 'style') {
+        if (typeof v === 'string') el.style.cssText = v;
+        else Object.assign(el.style, v);
+      } else if (k === 'className' || k === 'class') {
+        el.className = v;
+      } else if (k === 'dataset') {
+        for (const dk in v) el.dataset[dk] = v[dk];
+      } else if (k === 'html') {
+        el.innerHTML = v;
+      } else if (k.startsWith('on') && typeof v === 'function') {
+        el.addEventListener(k.slice(2).toLowerCase(), v);
+      } else if (k === 'ref' && typeof v === 'function') {
+        v(el);
+      } else if (k === 'checked' || k === 'disabled' || k === 'selected') {
+        if (v) el.setAttribute(k, '');
+      } else {
+        el.setAttribute(k, v);
+      }
+    }
+  } else if (attrs != null) {
+    children.unshift(attrs);
+  }
+  appendChildren(el, children);
+  return el;
+}
+function appendChildren(el, kids) {
+  for (const c of kids) {
+    if (c == null || c === false || c === true) continue;
+    if (Array.isArray(c)) appendChildren(el, c);
+    else if (c instanceof Node) el.appendChild(c);
+    else el.appendChild(document.createTextNode(String(c)));
+  }
+}
+
+// Format helpers
+const fmt = (v) => '$' + (v || 0).toLocaleString();
+const fmtCommas = (v) => (v || 0).toLocaleString();
+
+// ────────────────── STATE ──────────────────
+const STORAGE_KEY = 'cs_budget_tool_v1';
+const SUBMISSION_KEY = 'cs_budget_submission_v1';
+let state = {
+  page: 'landing',           // landing | wizard | loading | results
+  step: 0,                   // 0 | 1 | 2 (within wizard)
+  submissionId: null,        // received from /api/step1
+  data: defaultFormData(),
+  results: null,             // populated when /api/results returns ready
+  pollTimer: null,
+};
+
+function defaultFormData() {
+  return {
+    steamUrl: '', gameName: '', studioName: '', status: '', genre: [],
+    studioSize: '', studioCountry: '', releaseDate: '', pricePoint: null,
+    fundingType: '', devTime: '',
+    devBudget: null, artBudget: null, musicBudget: null, locBudget: null, marketingBudget: null,
+    wishlists: '',
+    socials: { twitter: 0, tiktok: 0, youtube: 0, discord: 0, reddit: 0 },
+    primaryChannel: '',
+    nextFest: false,
+    comparables: [{ name: '', url: '' }, { name: '', url: '' }, { name: '', url: '' }],
+  };
+}
+
+function saveState() {
+  try {
+    localStorage.setItem(STORAGE_KEY, JSON.stringify({ data: state.data, step: state.step, page: state.page }));
+    if (state.submissionId) localStorage.setItem(SUBMISSION_KEY, state.submissionId);
+  } catch (e) { /* private mode — ignore */ }
+}
+function loadState() {
+  try {
+    const raw = localStorage.getItem(STORAGE_KEY);
+    if (raw) {
+      const parsed = JSON.parse(raw);
+      if (parsed && parsed.data) {
+        state.data = Object.assign(defaultFormData(), parsed.data);
+        state.data.socials = Object.assign({ twitter:0,tiktok:0,youtube:0,discord:0,reddit:0 }, parsed.data.socials || {});
+        state.data.comparables = (parsed.data.comparables && parsed.data.comparables.length)
+          ? parsed.data.comparables : defaultFormData().comparables;
+      }
+    }
+    const sid = localStorage.getItem(SUBMISSION_KEY);
+    if (sid) state.submissionId = sid;
+  } catch (e) { /* ignore */ }
+}
