+    "founder_voice": "Direct, blunt, mildly self-deprecating. Match the verbatim site copy attached.",
+    "banned_words": ["unfortunately"],
+    "register": "indie peer to indie peer — not consultant-speak",
+    "do_not": [
+      "Invent specific numbers for comparables — only use comparables provided in the prompt",
+      "Promise outcomes ('we'll get you funded'). Frame in terms of clarity, optionality, runway.",
+      "Be saccharine. Don't open with empty validation."
+    ],
+    "do": [
+      "Name the specific gap — be concrete about what's missing.",
+      "Use the user's actual numbers (game name, studio, country, headcount, dev time, price).",
+      "End with the 'Get in touch' CTA on its own line."
+    ]
+  },
+  "structure": {
+    "paragraphs": "2-4 short paragraphs",
+    "anchors": [
+      "Biggest gap in the studio's funding-readiness right now",
+      "Most realistic funding path given the data — use user's Funding Type as primary lens, but flag if a different path looks materially better",
+      "Where Caspian Shift adds the most value (Claude picks; no fixed catalogue)"
+    ],
+    "closing": "Single CTA on its own line: 'Get in touch →' linking to /#contact?submissionId=..."
+  },
+  "special_hooks": {
+    "many_estimates": "If 3+ budget lines were estimated → nudge pinning down the budget as a near-term to-do.",
+    "no_steam_url_past_vertical_slice": "If no Steam URL AND status past Vertical Slice → flag setting up a Steam page.",
+    "price_derived": "If price was derived from comparables → flag pricing as a near-term decision.",
+    "low_traction": "If confidence band = Low → frame the report as directional and explicitly call out which numbers move first when traction data lands.",
+    "cross_path_alternative": "If Funding Type = Self-Funded but budget > $300k → mention publisher / grant might be a more realistic primary path."
+  },
+  "service_options_to_consider": [
+    { "id": "level_1_funding_analysis", "title": "Funding Analysis", "use_when": "Studio has a budget but it's directional — needs line-by-line audit and risk-adjustment." },
+    { "id": "level_2_funding_ready_pack", "title": "Funding Ready Pack", "use_when": "Studio is ready to pitch — needs deck, campaign page, target list." },
+    { "id": "level_3_launch_strategy", "title": "Launch Strategy", "use_when": "Studio is past Vertical Slice — needs Steam page optimisation, wishlist plan, creator outreach." }
+  ]
+}
