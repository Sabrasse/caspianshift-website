# Copy to .env for local `netlify dev`. In production, set these in Netlify dashboard
# (Site settings → Environment variables). Notion vars are required for the tool to write
# real data; if blank, every Notion call falls back to a no-op so the rest still works.

# Notion — Game Case Studies database (submissions land here)
NOTION_API_KEY=
NOTION_DB_ID=34abb949947480b2b326c2fe922f384c

# Notion — reference DBs for Caspian Shift recommendation cards
NOTION_PUBLISHER_DB_ID=
NOTION_CROWDFUNDING_DB_ID=
NOTION_GRANT_DB_ID=
