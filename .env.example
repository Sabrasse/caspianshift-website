# Copy to .env for local `netlify dev`. In production, set these in Netlify dashboard
# (Site settings → Environment variables). Every var is OPTIONAL — leaving any blank
# makes the corresponding integration fall back to a mock so the rest still works.

# Notion CRM (Game Case Studies database)
NOTION_API_KEY=
NOTION_DB_ID=34abb949947480b2b326c2fe922f384c

# Anthropic (Claude analysis)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Transactional email (Resend)
EMAIL_API_KEY=
EMAIL_FROM=Caspian Shift <hello@caspianshift.com>

# Internal token used by step3 → analyse-background. Generate any random string.
INTERNAL_TOKEN=
